{
  "name": "aiogram-webhook",
  "version": "1.0.0",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "npm run build:cli && npm run build:docs",
    "build:cli": "npm ci --prefix ./tools/diplodoc-cli && npm run build --prefix ./tools/diplodoc-cli",
    "build:docs": "rimraf docs-html docs-md && node ./tools/diplodoc-cli/build/index.js -i ./docs -o ./docs-html",
    "web": "http-server ./docs-html",
    "docs": "npm run build && npm run web"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com-m:m-xim/aiogram-webhook.git"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "http-server": "^14.1.1",
    "rimraf": "^6.0.1"
  }
}
