{
  "name": "aiogram-webhook",
  "version": "1.0.0",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "docs:build": "rimraf docs-html docs-md && yfm -i ./docs -o ./docs-html",
    "docs:build:md": "yfm -i ./docs -o ./docs-md --output-format md --add-map-file --allow-custom-resources",
    "docs:web": "http-server ./docs-html",
    "docs": "npm run docs:build && npm run docs:web"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com-m:m-xim/aiogram-webhook.git"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@diplodoc/cli": "5.39.6",
    "http-server": "^14.1.1",
    "rimraf": "^6.0.1"
  }
}