langs: ['en']

linkify: true
lint: true
sanitizeHtml: true
allowHtml: true # for metrika
staticContent: true
strict: true
supportGithubAnchors: true

vcs: true
mtimes: true
authors: true

extensions:
  - github-vcs
  - './extensions/vcs-control'
  - './extensions/breadcrumbs'
  - name: mdit-plugins
    plugins:
      - '@diplodoc/transform/lib/plugins/checkbox'

analytics:
  metrika:
    - id: 109620556
      params:
        clickmap: true
        webvisor: true
        accurateTrackBounce: true
        trackLinks: true

allowCustomResources: true
resources:
  style:
    - _assets/style/custom.css
  script:
    - _assets/script/fix_code_blocks.js

interface:
  favicon-src: _assets/brand/favicon.ico

docs-viewer: 
  project-name: aiogram-webhook
  lang: 'en'
  langs: ['en']
  logo-options:
    url: https://aiogram-webhooks.m-xim.ru
    src: _assets/brand/favicon.ico
    src-dark: _assets/brand/favicon.ico
    src-preview: _assets/brand/banner.png
    title: aiogram-webhook
  themes: ['dark', 'light']

search:
  provider: local

skipHtmlExtension: true

vcsControl:
  url: 'https://github.com/m-xim/aiogram-webhook/edit/main/docs/{path}'
  type: 'github'

breadcrumbs:
  tocAsRoot: true
  appendLabeled: false

codeHighlight:
  light: github
  dark: github-dark
